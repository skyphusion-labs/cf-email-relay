# Copy to /etc/cf-email-relay.env and fill in. Read by the systemd unit.
# Keep mode 0600 (it holds the relay token).

# Public /send endpoint of the deployed worker.
EMAIL_WORKER_URL=https://cf-email-relay.<account>.workers.dev/send

# Must match the worker's RELAY_TOKEN secret (wrangler secret put RELAY_TOKEN).
EMAIL_RELAY_TOKEN=replace-with-shared-secret

# Where the relay listens for local SMTP. Comma-separated for multiple binds:
# loopback for host services, plus a docker-bridge IP if a container needs to
# reach it. Bind specific private IPs, never 0.0.0.0 (the relay sends as your
# domain, so an externally reachable port is abusable).
# Example: SMTP_LISTEN=127.0.0.1:2525,172.18.0.1:2525
SMTP_LISTEN=127.0.0.1:2525

# Optional. If FROM_DOMAIN is set, any sender not on it is rewritten to
# DEFAULT_FROM (with the original kept as Reply-To). Leave both empty to pass
# the original From through unchanged.
DEFAULT_FROM=
FROM_DOMAIN=
